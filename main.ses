{load_file("nrngui.hoc")}
objectvar save_window_, rvp_
objectvar scene_vector_[6]
objectvar ocbox_, ocbox_list_, scene_, scene_list_
{ocbox_list_ = new List()  scene_list_ = new List()}
{pwman_place(0,0,0)}

// --- 1. RunControl Panel ---
{
xpanel("RunControl", 0)
v_init = -87.75
xvalue("Init","v_init", 1,"stdinit()", 1, 1 )
xbutton("Init & Run","run()")
xbutton("Stop","stoprun=1")
runStopAt = 5
xvalue("Continue til","runStopAt", 1,"{continuerun(runStopAt) stoprun=1}", 1, 1 )
runStopIn = 1
xvalue("Continue for","runStopIn", 1,"{continuerun(t + runStopIn) stoprun=1}", 1, 1 )
xbutton("Single Step","steprun()")
t = 0
xvalue("t","t", 2 )
tstop = 900
xvalue("Tstop","tstop", 1,"tstop_changed()", 0, 1 )
dt = 0.01
xvalue("dt","dt", 1,"setdt()", 0, 1 )
steps_per_ms = 100
xvalue("Points plotted/ms","steps_per_ms", 1,"setdt()", 0, 1 )
screen_update_invl = 0.05
xvalue("Scrn update invl","screen_update_invl", 1,"", 0, 1 )
realtime = 0
xvalue("Real Time","realtime", 0,"", 0, 1 )
xpanel(20,50)
}

// --- 2. Somatic Current Clamp (IClamp) Control Panel ---
{
xpanel("Somatic IClamp Control", 0)
xvalue("Delay (ms)", "stim.del", 1, "", 0, 1)
xvalue("Duration (ms)", "stim.dur", 1, "", 0, 1)
xvalue("Amplitude (nA)", "stim.amp", 1, "", 0, 1)
xpanel(20,480)
}

// --- 3. Somatic Membrane Potential Graph ---
{
save_window_ = new Graph(0)
save_window_.size(0,900,-95,45)
scene_vector_[2] = save_window_
{save_window_.view(0, -95, 900, 140, 290, 50, 450, 350)}
graphList[0].append(save_window_)
save_window_.save_name("graphList[0].")
save_window_.addexpr("py.soma(0.5).v", 1, 1, 0.8, 0.9, 2)
save_window_.label(0.1, 0.95, "Somatic Membrane Potential (mV)")
}

// --- 4. Major Somatic Currents Graph ---
{
save_window_ = new Graph(0)
save_window_.size(0,900,-1.5,1.5)
scene_vector_[3] = save_window_
{save_window_.view(0, -1.5, 900, 3.0, 760, 50, 450, 350)}
graphList[1].append(save_window_)
save_window_.save_name("graphList[1].")
save_window_.addexpr("py.soma(0.5).ina_naf", 1, 1, 0.8, 0.9, 2) // Black: NaF
save_window_.addexpr("py.soma(0.5).ik_kaf", 6, 1, 0.8, 0.9, 2)  // Brown: KAf
save_window_.addexpr("py.soma(0.5).ik_kas", 2, 1, 0.8, 0.9, 2)  // Red: KAs
save_window_.addexpr("py.soma(0.5).ik_kir", 3, 1, 0.8, 0.9, 2)  // Blue: Kir
save_window_.addexpr("py.soma(0.5).ik_krp", 4, 1, 0.8, 0.9, 2)  // Green: Krp
save_window_.label(0.1, 0.95, "Somatic Currents (mA/cm^2)")
}

// --- 5. Somatic Calcium Pools Concentration Graph ---
{
save_window_ = new Graph(0)
save_window_.size(0,900,0,0.005)
scene_vector_[4] = save_window_
{save_window_.view(0, 0, 900, 0.005, 290, 440, 450, 300)}
graphList[2].append(save_window_)
save_window_.save_name("graphList[2].")
save_window_.addexpr("py.soma(0.5).cai", 2, 1, 0.8, 0.9, 2)   // Red: N/Q/R pool Ca
save_window_.addexpr("py.soma(0.5).cali", 3, 1, 0.8, 0.9, 2)  // Blue: L/T pool Ca
save_window_.label(0.1, 0.95, "Somatic Calcium Concentrations (mM)")
}

// --- 6. PlotShape (3D Morphology) ---
{
save_window_ = new PlotShape(0)
save_window_.size(-450,450,-450,450)
save_window_.variable("v")
scene_vector_[5] = save_window_
{save_window_.view(-450, -450, 900, 900, 760, 440, 450, 400)}
fast_flush_list.append(save_window_)
save_window_.save_name("fast_flush_list.")
}

{doNotify()}
